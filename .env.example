# 你的 HenrikDev API Key（放伺服器端，Nightbot 不會看到）
HENRIK_API_KEY=YOUR_API_KEY_HERE

# 伺服器監聽埠（部署平台通常會給 PORT）
PORT=3000

# 預設玩家（可選；你也可以完全靠 Nightbot 傳參數）
DEFAULT_REGION=ap
DEFAULT_NAME=YourName
DEFAULT_TAG=YourTag

# 快取秒數（避免重複打上游；建議 15~60）
CACHE_TTL_SECONDS=30

# 額外：限制同 IP 最低間隔（毫秒），避免被刷（可選）
MIN_INTERVAL_MS=500
